# 복사: cp .env.example .env  (미설정 시 개발용 폴백 사용 — 그대로 테스트 가능)

# --- 데이터 루트 ---
DATA_ROOT=./data

# --- 백엔드 선택 ---
# storage: local(기본) | minio
STORAGE_BACKEND=local
# task: inprocess(기본) | celery
TASK_BACKEND=inprocess
# catalog: sqlite(기본) | postgres
CATALOG_BACKEND=sqlite

# --- MinIO (STORAGE_BACKEND=minio) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# --- Redis/Celery (TASK_BACKEND=celery) ---
# Redis 는 centos9 안에서 네이티브로 구동 → localhost 사용
REDIS_URL=redis://localhost:6379/0

# --- PostgreSQL (CATALOG_BACKEND=postgres) ---
# postgres16 은 *별도 컨테이너* 이므로 localhost 가 아니라 그 컨테이너 IP/주소로 접속한다.
#   - 현재 검증된 값: 172.17.0.2:5432 (기본 bridge)  ·  DB=flopi  user=flopi_adm  pw=flopi1234
#   - 주의: 기본 bridge 의 컨테이너 IP 는 재시작 시 바뀔 수 있다.
#     안정적으로 쓰려면 두 컨테이너를 같은 user-defined network 에 두고 이름(postgres16)으로 접속:
#       docker network create lake && docker network connect lake centos9 && docker network connect lake postgres16
#       → POSTGRES_DSN=postgresql://flopi_adm:flopi1234@postgres16:5432/flopi
# POSTGRES_DSN=postgresql://flopi_adm:flopi1234@172.17.0.2:5432/flopi

# --- 조회 안전장치 ---
QUERY_ROW_LIMIT=10000
