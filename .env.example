# 복사: cp .env.example .env  (미설정 시 개발용 폴백 사용 — 그대로 테스트 가능)

# --- 데이터 루트 ---
DATA_ROOT=./data

# --- 백엔드 선택 ---
# storage: local(기본) | minio
STORAGE_BACKEND=local
# task: inprocess(기본) | celery
TASK_BACKEND=inprocess
# catalog: sqlite(기본) | postgres
CATALOG_BACKEND=sqlite

# --- MinIO (STORAGE_BACKEND=minio) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# --- Redis/Celery (TASK_BACKEND=celery) ---
# Redis 는 centos9 안에서 네이티브로 구동 → localhost 사용
REDIS_URL=redis://localhost:6379/0

# --- PostgreSQL (CATALOG_BACKEND=postgres) — 운영 표준 분리형 변수명 ---
# 우선순위: POSTGRES_DSN(단일) > PG_*(분리형). 실제 값은 .env 에만 채우세요(커밋 금지).
#PG_HOST=<db-host>
#PG_PORT=5432
#PG_USER=flopi_adm
#PG_PASSWORD=<password>
#PG_DB=flopi_db
# 또는 단일 DSN 으로:
#POSTGRES_DSN=postgresql://<user>:<password>@<host>:<port>/<db>

# --- 조회 안전장치 ---
QUERY_ROW_LIMIT=10000
